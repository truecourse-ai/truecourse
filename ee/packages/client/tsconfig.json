{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "jsx": "react-jsx",
    "types": ["node"],
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    // The Knowledge page reuses the OSS dashboard's spec/contract components via
    // the `@/*` alias, so source spans two locations — rootDir is the repo root.
    // (This package is built + typechecked by the OSS vite app that aliases
    // `@truecourse/ee-client` to this source; standalone tsc is not a gate.)
    "rootDir": "../../..",
    "baseUrl": ".",
    "paths": {
      "@/*": ["../../../apps/dashboard/client/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
