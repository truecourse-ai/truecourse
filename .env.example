# Claude Code CLI settings (optional — the `claude` binary is the only supported provider)
# CLAUDE_CODE_MODEL=
# CLAUDE_CODE_TIMEOUT_MS=120000

# ---------------------------------------------------------------------
# Enterprise edition (optional). The dashboard server loads env from
# ~/.truecourse/.env (reliable, absolute) and the repo-root .env (dev).
# Put real WorkOS secrets in ~/.truecourse/.env — never commit them.
# ---------------------------------------------------------------------

# Force the edition. If unset, enterprise turns on automatically when
# the WORKOS_* vars below are present. Values: enterprise | community
# TRUECOURSE_EDITION=enterprise

# Enterprise SSO via WorkOS AuthKit (from the WorkOS dashboard → API Keys).
# The API key begins with sk_test_ (staging) or sk_live_ (production).
# WORKOS_API_KEY=YOUR_WORKOS_API_KEY
# WORKOS_CLIENT_ID=YOUR_WORKOS_CLIENT_ID
# WORKOS_REDIRECT_URI=http://localhost:3001/api/ee/auth/callback
# WORKOS_APP_URL=http://localhost:3000
# 32+ char secret to seal the session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# WORKOS_COOKIE_PASSWORD=replace-with-a-32-byte-base64-secret
