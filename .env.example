# Claude Code CLI settings (optional — the `claude` binary is the only supported provider)
# CLAUDE_CODE_MODEL=
# CLAUDE_CODE_TIMEOUT_MS=120000

# ---------------------------------------------------------------------
# Enterprise edition (optional). The dashboard server loads env from
# ~/.truecourse/.env (reliable, absolute) and the repo-root .env (dev).
# Put real WorkOS secrets in ~/.truecourse/.env — never commit them.
# ---------------------------------------------------------------------

# Force the edition. If unset, enterprise turns on automatically when
# the WORKOS_* vars below are present. Values: enterprise | community
# TRUECOURSE_EDITION=enterprise

# Enterprise SSO via WorkOS AuthKit (from the WorkOS dashboard → API Keys).
# The API key begins with sk_test_ (staging) or sk_live_ (production).
# WORKOS_API_KEY=YOUR_WORKOS_API_KEY
# WORKOS_CLIENT_ID=YOUR_WORKOS_CLIENT_ID
# WORKOS_REDIRECT_URI=http://localhost:3001/api/ee/auth/callback
# WORKOS_APP_URL=http://localhost:3000
# 32+ char secret to seal the session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# WORKOS_COOKIE_PASSWORD=replace-with-a-32-byte-base64-secret

# ---------------------------------------------------------------------
# Enterprise GitHub App (PR gate) — optional. Lights up the `github-gate`
# capability when all four GITHUB_APP_* vars are present. From the GitHub
# App settings page (Settings → Developer settings → GitHub Apps).
# ---------------------------------------------------------------------
# GITHUB_APP_ID=123456
# Private key PEM. Use a raw PEM, an escaped single-line PEM (\n), or a
# base64-encoded PEM (recommended for env files):
#   base64 -i your-app.private-key.pem | tr -d '\n'
# GITHUB_APP_PRIVATE_KEY=base64-or-pem
# Webhook secret configured on the GitHub App (verifies inbound deliveries).
# GITHUB_APP_WEBHOOK_SECRET=replace-with-the-app-webhook-secret
# App slug from its public URL (github.com/apps/<slug>); used for the install link.
# GITHUB_APP_SLUG=truecourse-gate

# Email notifications via Resend (resend.com). Optional — sent to a repo's
# configured notify addresses when the drift gate fails, a PR adds spec docs to
# re-scan, or inference captures new contracts.
# RESEND_API_KEY=re_xxxxxxxx
# From address (must be a Resend-verified sender). Defaults to a placeholder.
# RESEND_FROM=TrueCourse <noreply@yourdomain.com>

# Hosted storage. When set, the enterprise server stores EVERYTHING server-side
# (analyses, drift, per-repo config, ui-state, the project registry, contracts,
# specs, and the LLM-stage caches) in this Postgres instead of the customer's
# `.truecourse/` tree — and the GitHub App stops committing contracts back to PR
# branches. Bulky artifacts go to BLOB_STORE below. Leave unset for local dev
# (file + git, unchanged). Migrations apply automatically at boot.
# DATABASE_URL=postgres://user:pass@host:5432/truecourse

# ---------------------------------------------------------------------
# Enterprise LLM provider. The OSS/local product runs the `claude` CLI;
# the enterprise edition calls an API provider instead, so a hosted deploy
# needs no CLI binary. The provider + key are configured IN-APP via the
# Models page (keys encrypted in Postgres). There is NO env/CLI provider
# fallback in enterprise — set it in the dashboard after signing in.
# ---------------------------------------------------------------------

# Master secret used to encrypt provider API keys at rest (AES-256-GCM).
# REQUIRED for enterprise, like DATABASE_URL — the server refuses to boot
# without it (32+ chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# TRUECOURSE_SECRET_KEY=replace-with-a-strong-32-byte-secret

# Override the local CLI binary used by the default (OSS) transport.
# CLAUDE_CODE_BIN=claude

# ---------------------------------------------------------------------
# Enterprise blob storage (optional). Where the hosted edition stores
# bulky artifacts (contract corpora, spec/analysis snapshots, caches).
# Cloud-agnostic; Azure is first-class. Default: postgres.
# ---------------------------------------------------------------------
# BLOB_STORE=postgres               # azure | s3 | postgres | fs

# Azure Blob Storage (native). Managed identity by default — no keys to store —
# so on Azure just set the account + container and grant the identity access.
# AZURE_STORAGE_ACCOUNT=mystorageacct
# AZURE_STORAGE_CONTAINER=truecourse
# AZURE_STORAGE_CONNECTION_STRING=  # optional; skips managed identity

# S3-compatible (AWS S3, MinIO/on-prem, R2, …). Set S3_ENDPOINT for non-AWS.
# S3_BUCKET=truecourse
# S3_REGION=us-east-1
# S3_ENDPOINT=                      # e.g. http://minio:9000 (MinIO/on-prem)
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_FORCE_PATH_STYLE=true          # required by MinIO; defaulted on for custom endpoints

# Filesystem (single-host / dev). postgres uses the same DATABASE_URL above.
# BLOB_FS_ROOT=/var/lib/truecourse/blobs

# ---------------------------------------------------------------------
# Enterprise error tracking (Sentry) — optional, EE only. When SENTRY_DSN
# is set, the EE server reports server-side exceptions (e.g. a failed
# Confluence/LLM key connect) attributed to the customer org, so operators
# can troubleshoot. EE-only: no OSS code reports, and only errors explicitly
# captured by EE code egress. Privacy-first by design — request bodies,
# headers, stack-frame locals/source, breadcrumbs, and PII are scrubbed
# before send; the user is reduced to an opaque org id. Leave unset to
# disable. Use an EU-region DSN for EU data residency.
# SENTRY_DSN=https://examplePublicKey@o0.ingest.de.sentry.io/0
# SENTRY_ENVIRONMENT=production        # defaults to NODE_ENV, then "production"
# SENTRY_RELEASE=                       # optional build/release tag for regressions
