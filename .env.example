# Database (optional — embedded PostgreSQL is used by default)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5434/truecourse

# LLM Providers (API key required for anthropic/openai, not needed for claude-code)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Default LLM provider: anthropic | openai | claude-code
LLM_PROVIDER=anthropic

# Claude Code CLI settings (only used when LLM_PROVIDER=claude-code)
# CLAUDE_CODE_MODEL=
# CLAUDE_CODE_TIMEOUT_MS=120000

# Langfuse tracing (optional — requires Docker: docker-compose up -d)
# After starting Langfuse, open http://localhost:3002, create a project, and paste keys here
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://localhost:3002

# Langfuse self-hosted (docker-compose secrets)
# Generate via: openssl rand -hex 32
LANGFUSE_ENCRYPTION_KEY=
