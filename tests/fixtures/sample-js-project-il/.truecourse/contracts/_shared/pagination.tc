pagination-contract pagination.cursor.standard {
  origin SPEC.md "Pagination" 40..49
  scheme cursor

  query {
    cursor: string optional semantics opaque
    limit: integer optional {
      default 20
      min 1
      max 50
      on-above-max clamp     // clamp to 50, do not reject
    }
  }

  response-shape {
    items: array element $context.list_element_type
    nextCursor: string|null semantics null-when-last-page
  }

  forbids {
    forbid query-param offset
    forbid query-param page
  }

  selector tag paginated
}
