error-envelope error.envelope.standard {
  origin SPEC.md "Error envelope" 22..38

  applies-to status-class [4xx, 5xx]

  shape {
    error {
      field code: string format machine-identifier required
      field message: string required constraint human-readable
      field details: object optional constraint shape-depends-on-code
    }
  }

  known-codes [
    validation_failed,
    unauthenticated,
    forbidden,
    order_not_found,
    customer_not_found,
    illegal_transition,
    email_taken,
  ]
}
