entity Customer {
  origin SPEC.md "Entities/Customer" 73..79

  field id: uuid {
    origin server-assigned
    immutable
  }

  field email: string {
    format email
    normalize lowercase
    unique
  }

  field name: string constraint non-empty

  field loyaltyTier: Enum:LoyaltyTier {
    default standard
    mutability mutable
  }

  field createdAt: iso-8601 {
    origin server-assigned
    immutable
  }
}
