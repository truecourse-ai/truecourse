operation GET "/api/orders" {
  origin SPEC.md "Operations — Orders / GET /api/orders" 115..122

  request {
    query {
      cursor: string optional
      limit: integer optional default 20 min 1 max 50
      status: Enum:OrderStatus optional
    }
  }

  response 200 on success {
    body {
      items: array element Entity:Order
      nextCursor: string|null
    }
    ordering {
      sort field placedAt direction desc
      scope global
    }
  }

  response 401 inherits AuthRequirement:auth.bearer.api

  tags [paginated]
}
