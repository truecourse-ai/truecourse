formula order.discount-cents {
  origin SPEC.md "Business rules / Pricing" 191..201

  output Entity:Order field discountCents

  inputs [
    Entity:Order.subtotalCents,
    Entity:Order.customerId,
    Entity:Customer.loyaltyTier,
  ]

  // Conditional formula. The verifier reads `when` as the condition under
  // which the non-zero branch applies; the `else` branch is the default.
  // Both branches are opaque expression strings — the Formula extractor
  // parses them at verify time using the same expression grammar it
  // applies to the implementation's source.
  expression {
    when "(customer.loyaltyTier == \"gold\") and (subtotalCents > 10000)"
    then "round(subtotalCents * 0.10)"
    else "0"
  }

  computed-at order-creation
  immutable-after-creation
}
