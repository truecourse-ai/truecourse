entity Order {
  origin SPEC.md "Entities/Order" 60..67

  field id: uuid {
    origin server-assigned
    immutable
  }

  field status: Enum:OrderStatus {
    origin derived
    bound-to StateMachine:Order.status
    mutability state-machine
  }

  field subtotalCents: integer >= 0 {
    immutable
  }

  field discountCents: integer >= 0 {
    origin derived
    derived-by Formula:order.discount-cents
    immutable
  }

  field taxCents: integer >= 0 {
    origin derived
    derived-by Formula:order.tax-cents
    immutable
  }

  field totalCents: integer >= 0 {
    origin derived
    derived-by Formula:order.total-cents
    immutable
  }

  field customerId: uuid {
    references Entity:Customer
    immutable
  }

  field placedAt: iso-8601 {
    origin server-assigned
    immutable
  }

  field updatedAt: iso-8601 {
    origin server-assigned
    mutability refreshed-on-mutation
  }
}
