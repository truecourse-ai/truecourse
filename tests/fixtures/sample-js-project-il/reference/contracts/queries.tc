// QueryRule contracts for the orders / customers / loyalty data layer.
//
// All query rules live in one file so the engine's cross-rule
// attribution of `query.unparseable` (a property of a code query, not of
// a single rule) is deterministic: the first-declared rule wins, so the
// loyalty rule is declared first.

query-rule loyalty-tiers.in-code {
  origin "reference/specs/modules/customers/data.md" "Loyalty tiers" 20..25
  entity Entity:LoyaltyTier
  required {
    in tiers.code ["bronze", "silver", "gold"]
  }
}

query-rule order.eq-tenantid {
  origin "reference/specs/modules/orders/data.md" "Tenant scoping" 30..34
  entity Entity:Order
  required {
    eq orders.tenantId "<param>"
  }
}

query-rule order.daterange-placedat {
  origin "reference/specs/modules/orders/data.md" "Date scoping" 35..38
  entity Entity:Order
  date-range-binding column orders.placedAt
}

query-rule order.no-is-null-deletedat {
  origin "reference/specs/modules/orders/data.md" "Soft delete" 39..42
  entity Entity:Order
  forbidden {
    is-null orders.deletedAt
  }
}

query-rule customer.in-status {
  origin "reference/specs/modules/customers/data.md" "Status allowlist" 26..29
  entity Entity:Customer
  required {
    in customers.status ["active", "pending"]
  }
}
