// Storage-strategy decision: the per-customer `marketingOptIn` preference is
// kept inside the customer `metadata` JSON blob rather than promoted to a
// dedicated column. Read through `customer.metadata.marketingOptIn` in
// code/src/services/customers.preferences.service.ts.
//
// `betaFeatures` is the same shape (a metadata-json key) but is deliberately
// left undocumented here, so `infer` surfaces it as a reverse-engineered
// decision (see reference/contracts/_inferred/_shared/persistence.betafeatures.tc).

architecture-decision persistence.marketingOptIn {
  origin "reference/specs/modules/customers/data.md" "Preference storage" 31..35
  category persistence-strategy
  chosen metadata-json
  reason "Read-mostly preference flag, never filtered in a hot path — not worth a dedicated column"
  consequences [
    "Cannot index or filter customers by marketing opt-in at the database level",
    "Schema migrations are unnecessary when adding sibling preference flags"
  ]
}
