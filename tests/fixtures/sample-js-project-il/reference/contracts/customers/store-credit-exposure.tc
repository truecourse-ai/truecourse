// Read-path field exposure (DIVERGENT case): a customer's `storeCredit` balance
// must travel on the billing read path — it is included in the read projection
// (the Prisma `select` the billing-summary query asks for) so the balance
// reaches the consumer. The exposure site SHOULD be `readBillingSummary` in
// code/src/services/customers.billing.service.ts, but that projection omits
// `storeCredit`, so it is never selected and never reaches the consumer.

field-exposure customer.store-credit-exposed {
  origin "reference/specs/modules/customers/data.md" "Billing summary projection" 51..56
  field Entity:Customer.storeCredit
  via query-select
  in readBillingSummary
}
