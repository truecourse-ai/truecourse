operation GET "/api/customers" {
  origin ".truecourse/reference/specs/modules/customers/endpoints.md" "GET /api/customers" 18..20
  request {
    query {
      cursor: string optional
      limit: integer optional default 20 min 1 max 50
    }
  }
  response 200 on success {
    body {
      items: array element Entity:Customer
      nextCursor: string|null
    }
  }
  response 401 inherits AuthRequirement:auth.bearer.api
  tags [paginated]
}
