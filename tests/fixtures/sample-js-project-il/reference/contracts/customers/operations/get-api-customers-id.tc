operation GET "/api/customers/{id}" {
  origin "reference/specs/modules/customers/endpoints.md" "GET /api/customers/:id" 22..25
  request {
    path-param id: uuid {
      on-invalid status 400 error-code validation_failed
    }
  }
  response 200 on success {
    body Entity:Customer
  }
  response 404 on not_found {
    body envelope ErrorEnvelope:error.envelope.standard {
      error-code customer_not_found
    }
    forbid status 200 when resource-missing
  }
  response 401 inherits AuthRequirement:auth.bearer.api
}
