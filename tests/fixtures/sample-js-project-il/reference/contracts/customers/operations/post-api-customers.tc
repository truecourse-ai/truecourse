operation POST "/api/customers" {
  origin "reference/specs/modules/customers/endpoints.md" "POST /api/customers" 3..16
  request {
    header content-type required value "application/json"
    body {
      email: string format email
      name: string constraint non-empty
    }
  }
  response 201 on success {
    body Entity:Customer
    header location required format "/api/customers/{id}"
  }
  response 400 on validation_failure {
    body envelope ErrorEnvelope:error.envelope.standard {
      error-code validation_failed
    }
  }
  response 409 on conflict {
    body envelope ErrorEnvelope:error.envelope.standard {
      error-code email_taken
    }
  }
  response 401 inherits AuthRequirement:auth.bearer.api
  response 403 inherits AuthRequirement:auth.role.admin
}
