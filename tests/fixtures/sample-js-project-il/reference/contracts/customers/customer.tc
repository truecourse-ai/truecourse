entity Customer {
  origin "reference/specs/modules/customers/data.md" "Customer" 3..10
  field id: uuid {
    origin server-assigned
    immutable
  }
  field email: string {
    format email
    normalize lowercase
    unique
  }
  field name: string constraint non-empty
  field loyaltyTier: Enum:LoyaltyTier {
    default standard
    mutability mutable
  }
  field createdAt: iso-8601 {
    origin server-assigned
    immutable
  }
}
