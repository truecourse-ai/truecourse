{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "paths": {
      "@sample/shared-utils": ["./shared/utils/src/index.ts"],
      "@app/*": ["./packages/*/src/*", "./packages/*/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
