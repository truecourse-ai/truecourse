entity Order {
  origin "reference/specs/modules/orders/data.md" "Order" 3..15
  field id: uuid {
    origin server-assigned
    immutable
  }
  field status: Enum:OrderStatus {
    bound-to StateMachine:Order.status
    mutability state-machine
  }
  field subtotal_cents: integer >= 0 {
    immutable
  }
  field discount_cents: integer >= 0 {
    origin derived
    derived-by Formula:order.discount-cents
    immutable
  }
  field tax_cents: integer >= 0 {
    origin derived
    derived-by Formula:order.tax-cents
    immutable
  }
  field customer_id: uuid {
    references Entity:Customer
    immutable
  }
  field placed_at: iso-8601 {
    origin server-assigned
    immutable
  }
  field updated_at: iso-8601 {
    origin server-assigned
    mutability refreshed-on-mutation
  }
}
