{
  "name": "@truecourse/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./analyze": {
      "types": "./dist/commands/analyze-in-process.d.ts",
      "import": "./dist/commands/analyze-in-process.js"
    },
    "./progress": {
      "types": "./dist/socket/handlers.d.ts",
      "import": "./dist/socket/handlers.js"
    },
    "./config/paths": {
      "types": "./dist/config/paths.d.ts",
      "import": "./dist/config/paths.js"
    },
    "./config/registry": {
      "types": "./dist/config/registry.d.ts",
      "import": "./dist/config/registry.js"
    },
    "./config/project-config": {
      "types": "./dist/config/project-config.d.ts",
      "import": "./dist/config/project-config.js"
    },
    "./config/database": {
      "types": "./dist/config/database.d.ts",
      "import": "./dist/config/database.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.4",
    "@truecourse/analyzer": "workspace:*",
    "@truecourse/shared": "workspace:*",
    "chokidar": "^4.0.0",
    "cors": "^2.8.5",
    "dagre": "^0.8.5",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.38.0",
    "express": "^4.21.0",
    "posthog-node": "^4.0.0",
    "simple-git": "^3.27.0",
    "socket.io": "^4.8.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/dagre": "^0.7.52",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
