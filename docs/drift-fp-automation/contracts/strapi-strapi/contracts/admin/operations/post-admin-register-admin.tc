operation POST "/admin/register-admin" {
  origin "docs/docs/docs/01-core/authentication/00-sessions-and-jwt.md" "Admin authentication" 43..90
  status shipped
  request {
    body {
      deviceId: string optional
      rememberMe: boolean optional
    }
  }
  response 200 on success {
    body {
      data {
        token: string
      }
    }
  }
}
